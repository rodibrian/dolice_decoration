Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Serve static assets from /public without exposing /public in the URL
  RewriteRule ^assets/(.*)$ public/assets/$1 [L]
  RewriteRule ^uploads/(.*)$ public/uploads/$1 [L]

  # If the requested path is an existing file/dir, serve it as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # All other requests go through the front-controller
  RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

